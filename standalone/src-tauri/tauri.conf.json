{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "邮件WeLink单机助手",
  "version": "0.1.0",
  "identifier": "com.standalone.emailwelink",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "邮件 / WeLink 单机助手",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../sidecar/outlook_cli/dist/outlook_cli.exe": "outlook_cli.exe"
    }
  }
}
